{
    "SET": {
        "summary": "Sets the string value of a key, ignoring its type. The key is created if it doesn't exist.",
        "complexity": "O(1)",
        "group": "string",
        "since": "1.0.0",
        "arity": -3,
        "command_flags": [
            "DENYOOM",
            "WRITE"
        ],
        "acl_categories": [
            "SLOW",
            "STRING",
            "WRITE"
        ],
        "arguments": [
            {
                "name": "key",
                "type": "key",
                "key_spec_index": 0
            },
            {
                "name": "value",
                "type": "string"
            },
            {
                "name": "condition",
                "type": "oneof",
                "since": "2.6.12",
                "arguments": [
                    {
                        "name": "nx",
                        "type": "pure-token",
                        "token": "NX"
                    },
                    {
                        "name": "xx",
                        "type": "pure-token",
                        "token": "XX"
                    }
                ],
                "optional": true
            },
            {
                "name": "get",
                "type": "pure-token",
                "token": "GET",
                "since": "6.2.0",
                "optional": true
            },
            {
                "name": "expiration",
                "type": "oneof",
                "arguments": [
                    {
                        "name": "seconds",
