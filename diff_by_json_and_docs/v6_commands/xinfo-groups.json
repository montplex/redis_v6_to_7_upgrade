{
    "XINFO|GROUPS": {
        "summary": "Returns a list of the consumer groups of a stream.",
        "complexity": "O(1)",
        "group": "stream",
        "since": "5.0.0",
        "arity": 3,
        "command_flags": [
            "READONLY"
        ],
        "acl_categories": [
            "READ",
            "SLOW",
            "STREAM"
        ],
        "arguments": [
            {
                "name": "key",
                "type": "key",
                "key_spec_index": 0
            }
        ],
        "key_specs": [
            {
                "flags": [
                    "RO",
                    "ACCESS"
                ],
                "begin_search": {
                    "index": {
                        "pos": 2
                    }
                },
                "find_keys": {
                    "range": {
                        "lastkey": 2,
                        "step": 1,
                        "limit": 0
                    }
                }
            }
        ],
        "reply_schema": {
            "type": "array",
            "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                    "name": {
                        "type": "string"
                    },
                    "consumers": {
                        "type": "integer"
                    },
                    "pending": {
                        "type": "integer"
                    },
                    "last-delivered-id": {
                        "type": "string",
                        "pattern": "[0-9]+-[0-9]+"
                    },
                    "entries-read": {
                        "oneOf": [
                            {
                                "type": "null"
                            },
                            {
                                "type": "integer"
                            }
                        ]
                    },
                    "lag": {
                        "oneOf": [
                            {
                                "type": "null"
                            },
                            {
                                "type": "integer"
                            }
                        ]
                    }
                }
            }
        }
    }
}