{
    "PERSIST": {
        "summary": "Removes the expiration time of a key.",
        "complexity": "O(1)",
        "group": "generic",
        "since": "2.2.0",
        "arity": 2,
        "command_flags": [
            "FAST",
            "WRITE"
        ],
        "acl_categories": [
            "FAST",
            "KEYSPACE",
            "WRITE"
        ],
        "arguments": [
            {
                "name": "key",
                "type": "key",
                "key_spec_index": 0
            }
        ],
        "key_specs": [
            {
                "flags": [
                    "RW",
                    "UPDATE"
                ],
                "begin_search": {
                    "index": {
                        "pos": 1
                    }
                },
                "find_keys": {
                    "range": {
                        "lastkey": 1,
                        "step": 1,
                        "limit": 0
                    }
                }
            }
        ],
        "reply_schema": {
            "oneOf": [
                {
                    "const": 0,
                    "description": "Key does not exist or does not have an associated timeout."
                },
                {
                    "const": 1,
                    "description": "The timeout has been removed."
                }
            ]
        }
    }
}