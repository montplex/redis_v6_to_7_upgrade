{
    "SETEX": {
        "summary": "Sets the string value and expiration time of a key. Creates the key if it doesn't exist.",
        "complexity": "O(1)",
        "group": "string",
        "since": "2.0.0",
        "arity": 4,
        "command_flags": [
            "DENYOOM",
            "WRITE"
        ],
        "acl_categories": [
            "SLOW",
            "STRING",
            "WRITE"
        ],
        "arguments": [
            {
                "name": "key",
                "type": "key",
                "key_spec_index": 0
            },
            {
                "name": "seconds",
                "type": "integer"
            },
            {
                "name": "value",
                "type": "string"
            }
        ],
        "key_specs": [
            {
                "flags": [
                    "RW",
                    "UPDATE"
                ],
                "begin_search": {
                    "index": {
                        "pos": 1
                    }
                },
                "find_keys": {
                    "range": {
                        "lastkey": 1,
                        "step": 1,
                        "limit": 0
                    }
                }
            }
        ],
        "reply_schema": {
            "const": "OK"
        },
        "deprecated_since": "2.6.12",
        "replaced_by": "`SET` with the `EX` argument"
    }
}