{
    "SCRIPT|FLUSH": {
        "summary": "Removes all server-side Lua scripts from the script cache.",
        "complexity": "O(N) with N being the number of scripts in cache",
        "group": "scripting",
        "since": "2.6.0",
        "arity": -2,
        "command_flags": [
            "NOSCRIPT"
        ],
        "acl_categories": [
            "SCRIPTING",
            "SLOW"
        ],
        "arguments": [
            {
                "name": "flush-type",
                "type": "oneof",
                "since": "6.2.0",
                "arguments": [
                    {
                        "name": "async",
                        "type": "pure-token",
                        "token": "ASYNC"
                    },
                    {
                        "name": "sync",
                        "type": "pure-token",
                        "token": "SYNC"
                    }
                ],
                "optional": true
            }
        ],
        "history": [
            [
                "6.2.0",
                "Added the `ASYNC` and `SYNC` flushing mode modifiers."
            ]
        ],
        "reply_schema": {
            "const": "OK"
        }
    }
}