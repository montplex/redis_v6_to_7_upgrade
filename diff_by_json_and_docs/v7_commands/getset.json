        "group": "string",
        "since": "1.0.0",
        "arity": 3,
        "command_flags": [
            "DENYOOM",
            "FAST",
            "WRITE"
        ],
        "acl_categories": [
            "FAST",
            "STRING",
            "WRITE"
        ],
        "key_specs": [
            {
                "flags": [
                    "RW",
                    "UPDATE"
                ],
                "begin_search": {
                    "index": {
                        "pos": 1
                    }
                },
                "find_keys": {
                    "range": {
                        "lastkey": 1,
                        "step": 1,
                        "limit": 0
                    }
                }
            }
        ],
        "arguments": [
